{# Rendered by infra-ovh openstack role, once per loadbalancer host.
   Drops to node_custom_config/keepalived/<inventory_hostname>/keepalived.conf
   so kolla's loadbalancer role picks the per-host file via with_first_found.

   Multi-LB unicast VRRP on wg0:
   - unicast_src_ip is THIS host's wg0 IP
   - unicast_peer lists the wg0 IPs of every OTHER loadbalancer host
   - first host in the sorted loadbalancer list becomes MASTER (highest
     priority), the rest are BACKUP. `nopreempt` makes failover sticky
     so the previous master returning doesn't cause a flap.
-#}
{%- set _lb_host = openstack_kolla_keepalived_target_host -%}
{%- set _self_ip = hostvars[_lb_host].wireguard_address | regex_replace('/.*$', '') -%}
{%- set _peer_ips = openstack_kolla_loadbalancer_hosts
      | reject('equalto', _lb_host)
      | map('extract', hostvars, 'wireguard_address')
      | map('regex_replace', '/.*$', '')
      | list -%}
{%- set _sorted_lbs = openstack_kolla_loadbalancer_hosts | sort -%}
{%- set _is_primary = (_lb_host == _sorted_lbs[0]) -%}
global_defs {
    router_id LVS_KOLLA
    vrrp_skip_check_adv_addr
    vrrp_garp_master_refresh 60
}

vrrp_instance kolla_internal_vip_51 {
    state {{ 'MASTER' if _is_primary else 'BACKUP' }}
    nopreempt
    interface {{ openstack_kolla_tunnel_interface }}
    dont_track_primary
    virtual_router_id 51
    priority {{ 200 if _is_primary else 100 }}
    advert_int 1
    unicast_src_ip {{ _self_ip }}
    unicast_peer {
{% for peer_ip in _peer_ips %}
        {{ peer_ip }}
{% endfor %}
    }
    virtual_ipaddress {
        {{ openstack_kolla_internal_vip_address }} dev {{ openstack_kolla_tunnel_interface }}
        {{ openstack_kolla_external_vip_address }} dev {{ openstack_kolla_tunnel_interface }}
    }
}

