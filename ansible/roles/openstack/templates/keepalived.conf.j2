{# Rendered by infra-ovh openstack role. Final file is dropped into
   node_custom_config/keepalived/keepalived.conf so kolla's loadbalancer
   role picks it up via with_first_found. All Jinja substitutions happen
   here at our render time; the resulting file contains no Jinja markers,
   so kolla's later template pass leaves it untouched.

   Why this override: the loadbalancer host attaches keepalived to wg0,
   which is point-to-point and does NOT support multicast (`no multicast`
   in `ip link`). Kolla's default keepalived.conf uses multicast VRRP,
   which leaves the instance in a permanent "config fault" / BACKUP state
   on wg0 and the VIPs are never bound. Unicast VRRP with no peers (we
   have a single LB) sidesteps the multicast requirement and the instance
   transitions to MASTER cleanly.
-#}
global_defs {
    router_id LVS_KOLLA
    vrrp_skip_check_adv_addr
    vrrp_garp_master_refresh 60
}

vrrp_script check_alive {
    script "/check_alive.sh"
    interval 2
    fall 2
    rise 10
}

vrrp_instance kolla_internal_vip_51 {
    state MASTER
    nopreempt
    interface {{ openstack_kolla_tunnel_interface }}
    virtual_router_id 51
    priority 100
    advert_int 1
    unicast_src_ip {{ openstack_kolla_loadbalancer_wireguard_ip }}
    unicast_peer {
    }
    virtual_ipaddress {
        {{ openstack_kolla_internal_vip_address }} dev {{ openstack_kolla_tunnel_interface }}
        {{ openstack_kolla_external_vip_address }} dev {{ openstack_kolla_tunnel_interface }}
    }
    track_script {
        check_alive
    }
}

