# Generated by Ansible role openstack_kolla_minimal
kolla_base_distro: "{{ openstack_kolla_base_distro }}"
kolla_install_type: "{{ openstack_kolla_install_type }}"
openstack_release: "{{ openstack_kolla_release }}"

# Use default host NIC for API traffic and WireGuard for overlay/tenant traffic.
network_interface: "{{ openstack_kolla_network_interface }}"
tunnel_interface: "{{ openstack_kolla_tunnel_interface }}"
kolla_internal_vip_address: "{{ openstack_kolla_internal_vip_address }}"
kolla_external_vip_address: "{{ openstack_kolla_external_vip_address }}"

enable_horizon: "{{ openstack_kolla_enable_horizon | ternary('yes', 'no') }}"
enable_prometheus: "{{ openstack_kolla_enable_prometheus | ternary('yes', 'no') }}"
enable_grafana: "{{ openstack_kolla_enable_grafana | ternary('yes', 'no') }}"
enable_prometheus_server_external: "no"
enable_prometheus_alertmanager_external: "no"
enable_prometheus_openstack_exporter_external: "no"

enable_cinder: "no"
enable_cinder_backup: "no"
enable_swift: "no"
enable_ironic: "no"
enable_magnum: "no"
enable_trove: "no"
enable_sahara: "no"
enable_octavia: "no"
enable_manila: "no"
enable_barbican: "no"
enable_ceilometer: "no"
enable_gnocchi: "no"
enable_aodh: "no"
enable_cloudkitty: "no"

nova_compute_virt_type: "{{ openstack_kolla_nova_compute_virt_type }}"
