# Generated by Ansible role openstack_kolla_minimal
kolla_base_distro: "{{ openstack_kolla_base_distro }}"
kolla_install_type: "{{ openstack_kolla_install_type }}"
openstack_release: "{{ openstack_kolla_release }}"
openstack_tag_suffix: "{{ openstack_kolla_openstack_tag_suffix }}"

# Keep OpenStack control/data plane on WireGuard for this lab topology.
network_interface: "{{ openstack_kolla_tunnel_interface }}"
tunnel_interface: "{{ openstack_kolla_tunnel_interface }}"
kolla_internal_vip_address: "{{ openstack_kolla_internal_vip_address }}"
kolla_external_vip_address: "{{ openstack_kolla_external_vip_address }}"
node_custom_config: "{{ openstack_kolla_node_custom_config_dir }}"

enable_horizon: "{{ openstack_kolla_enable_horizon | ternary('yes', 'no') }}"
enable_prometheus: "{{ openstack_kolla_enable_prometheus | ternary('yes', 'no') }}"
enable_grafana: "{{ openstack_kolla_enable_grafana | ternary('yes', 'no') }}"
enable_central_logging: false
enable_fluentd: false
haproxy_stats_port: 2984
enable_prometheus_server_external: "no"
enable_prometheus_alertmanager_external: "no"
enable_prometheus_openstack_exporter_external: "no"
prometheus_haproxy_user: "admin"
prometheus_haproxy_password: "prometheus-internal"
prometheus_alertmanager_user: "admin"
prometheus_alertmanager_password: "alertmanager-internal"

enable_cinder: "{{ openstack_kolla_enable_cinder | ternary('yes', 'no') }}"
enable_cinder_backup: "{{ openstack_kolla_enable_cinder_backup | ternary('yes', 'no') }}"
enable_cinder_backend_lvm: "{{ openstack_kolla_enable_cinder_backend_lvm | ternary('yes', 'no') }}"
cinder_volume_group: "{{ openstack_kolla_cinder_volume_group }}"
enable_swift: "no"
enable_ironic: "no"
enable_magnum: "no"
enable_trove: "no"
enable_sahara: "no"
enable_octavia: "{{ openstack_kolla_enable_octavia | ternary('yes', 'no') }}"
enable_octavia_jobboard: "{{ openstack_kolla_enable_octavia_jobboard | ternary('yes', 'no') }}"
enable_valkey: "{{ openstack_kolla_enable_valkey | ternary('yes', 'no') }}"
enable_manila: "no"
enable_barbican: "no"
enable_ceilometer: "no"
enable_gnocchi: "no"
enable_aodh: "no"
enable_cloudkitty: "no"

octavia_certs_country: "{{ openstack_kolla_octavia_certs_country }}"
octavia_certs_state: "{{ openstack_kolla_octavia_certs_state }}"
octavia_certs_organization: "{{ openstack_kolla_octavia_certs_organization }}"
octavia_certs_organizational_unit: "{{ openstack_kolla_octavia_certs_organizational_unit }}"
octavia_certs_server_ca_common_name: "{{ openstack_kolla_octavia_certs_server_ca_common_name }}"
octavia_certs_client_ca_common_name: "{{ openstack_kolla_octavia_certs_client_ca_common_name }}"
octavia_certs_client_req_common_name: "{{ openstack_kolla_octavia_certs_client_req_common_name }}"

nova_compute_virt_type: "{{ openstack_kolla_nova_compute_virt_type }}"

docker_disable_systemd_unit: "no"
